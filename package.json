{
  "name": "wechat-codex-code",
  "version": "1.0.0",
  "description": "Chat with Codex CLI from WeChat - a local bridge from personal WeChat to Codex",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
    "start": "node dist/main.js",
    "run": "node dist/main.js start",
    "dev": "tsc --watch",
    "test": "node --test dist/tests/*.test.js",
    "setup": "node dist/main.js setup",
    "daemon": "node scripts/daemon.mjs",
    "autostart": "node scripts/autostart-windows.mjs",
    "visualize": "echo Log visualizer is not available in the Codex fork yet."
  },
  "dependencies": {
"qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.0",
    "typescript": "^5.7.0"
  },
  "keywords": ["wechat", "codex", "codex-cli", "bridge", "chat", "skill"],
  "author": "Wechat-ggGitHub, Codex fork",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wechat-ggGitHub/wechat-claude-code.git"
  }
}
